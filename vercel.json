{
  "version": 2,
  "builds": [
    {
      "src": "Backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/$1",
      "continue": true
    }
  ]
}
